{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "webkernel/webkernel",
    "description": "Webkernel is a sovereign application foundation that lets organizations own, control, and scale their business software without subscriptions, cloud lock-in, or vendor dependency.",
    "type": "project",
    "license": "EPL-2.0",
    "keywords": [
        "webkernel",
        "framework"
    ],
    "require": {
        "webkernel/composer-merger": "^0.1.4",
        "calebporzio/sushi": "*",
        "filament/filament": "*",
        "jeremykendall/php-domain-parser": "*",
        "laravel/framework": "*",
        "laravel/tinker": "*",
        "laravel/octane": "*",
        "laravel/pail": "*",
        "laravel/prompts": "*",
        "laravel/sanctum": "*",
        "livewire/blaze": "*",
        "nikic/php-parser": "*"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "fakerphp/faker": "^1.23",
        "fruitcake/laravel-debugbar": "^4.0",
        "laravel/sail": "^1.41",
        "pestphp/pest": "^4.1.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "psr/log": "^3.0",
        "rector/rector": "^2.3",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php internal/webkernel/tools/call-tools.php installer/guard package:discover"
        ],
        "post-create-project-cmd": [
            "@php internal/webkernel/tools/call-tools.php key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php internal/webkernel/tools/call-tools.php migrate --graceful --ansi"
        ],
        "post-update-cmd": [
            "@php internal/webkernel/tools/call-tools.php vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php internal/webkernel/tools/call-tools.php key:generate",
            "@php internal/webkernel/tools/call-tools.php migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php internal/webkernel/tools/call-tools.php config:clear --ansi",
            "@php internal/webkernel/tools/call-tools.php test"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "prod-deploy": [
            "composer install --no-dev --optimize-autoloader --prefer-dist --no-interaction --no-progress",
            "@php internal/webkernel/tools/call-tools.php down --retry=60 && php -r \"echo 'Deployment in progress...';\"",
            "@php internal/webkernel/tools/call-tools.php migrate --force",
            "composer w-cache",
            "npm ci",
            "npm run build -- --mode=production",
            "@php internal/webkernel/tools/call-tools.php up"
        ],
        "dev-setup": [
            "composer install --prefer-dist",
            "composer dump-autoload",
            "@php internal/webkernel/tools/call-tools.php migrate --seed",
            "@php internal/webkernel/tools/call-tools.php ide-helper:generate",
            "@php internal/webkernel/tools/call-tools.php ide-helper:models -M",
            "npm ci",
            "composer w-clear"
        ],
        "w-clear": [
            "@php internal/webkernel/tools/call-tools.php cache/clear"
        ],
        "w-clear-sudo": [
            "@php internal/webkernel/tools/call-tools.php installer/guard ensure-storage-dirs",
            "@php internal/webkernel/tools/call-tools.php installer/guard fix-permissions",
            "@php internal/webkernel/tools/call-tools.php installer/guard run-as-owner composer w-clear"
        ],
        "ws-clear": [
            "@php internal/webkernel/tools/call-tools.php cache/cached"
        ],
        "w-cache": [
            "@php internal/webkernel/tools/call-tools.php cache/cache"
        ],
        "ide-helper": [
            "@php internal/webkernel/tools/call-tools.php clear-compiled",
            "@php internal/webkernel/tools/call-tools.php ide-helper:eloquent",
            "@php internal/webkernel/tools/call-tools.php ide-helper:generate",
            "@php internal/webkernel/tools/call-tools.php ide-helper:models -M",
            "@php internal/webkernel/tools/call-tools.php ide/ide-helper-generator _ide_helper_webkernel.php"
        ]
    },
    "extra": {
        "merge-plugin": {
            "include": [
                "internal/composer.json",
                "internal/webkernel/composer.json",
                "modules/**/**/**/composer.json"
            ],
            "recurse": false,
            "replace": false,
            "ignore-duplicates": false,
            "merge-dev": true,
            "merge-extra": true,
            "merge-extra-deep": true,
            "merge-scripts": true
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "webkernel/composer-merger": true
        },
        "vendor-dir": "packages"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
